# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Postgres (prod)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/midnightshader?schema=public

# Auth
JWT_SECRET=change-me
JWT_COOKIE_NAME=midnightshader_token
JWT_EXPIRES_IN=7d

# S3-compatible storage (R2, MinIO, AWS S3, ...)
S3_ENDPOINT=https://s3.your-provider.example
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET=midnightshader-community
# Optional: set for public buckets (or if you serve objects via CDN)
S3_PUBLIC_BASE_URL=https://cdn.your-domain.example

